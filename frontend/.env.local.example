# =========================================================================
# FITABLE 体験予約システム 環境変数設定テンプレート
# =========================================================================
# ローカル開発時はこのファイルを `.env.local` にリネームして実際のキーを入力してください。
# Vercel本番環境では、Vercelの管理画面「Environment Variables」にこれらのキーを追加してください。

# -------------------------------------------------------------------------
# 1. Firebase Admin SDK 設定 (Secure Firestore Access)
# -------------------------------------------------------------------------
# Firebaseコンソール > プロジェクトの設定 > サービスアカウント > 「新しい秘密鍵の生成」から取得
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# 秘密鍵（改行コード \n を含んだ1行の長いテキスト文字列として入力します）
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------------------------
# 2. Google APIs & Calendar Service Account 設定
# -------------------------------------------------------------------------
# Google Cloud Console で作成したサービスアカウントの認証情報。上記Firebase Adminキーと同一プロジェクトなら共通でも構いません。
GOOGLE_SERVICE_ACCOUNT_EMAIL=calendar-service-account@your-gcp-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------------------------
# 3. Gmail SMTP 送信設定 (Nodemailer)
# -------------------------------------------------------------------------
# 体験予約確定時の自動返信メールを送るGmailアカウントのメールアドレス
GMAIL_USER=your-gym-email@gmail.com
# Google アカウントの「2段階認証プロセス」設定画面から生成した「アプリパスワード（16桁のアルファベット）」
GMAIL_PASS=xxxxwxxxyyyyzzzz

# -------------------------------------------------------------------------
# 4. アプリケーション全般設定
# -------------------------------------------------------------------------
# 管理画面に初回ログイン・データ移行する際の暗証コード
ADMIN_PIN=1234
# メールのキャンセル用リンクのベースURL (例: https://fitable-booking.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
