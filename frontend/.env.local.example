# =========================================================================
# FITABLE 体験予約システム 環境変数設定テンプレート (Supabase + Netlify版)
# =========================================================================
# ローカル開発時はこのファイルを `.env.local` にコピーして実際のキーを入力してください。
# Netlify本番環境では、Netlifyの管理画面「Environment Variables」にこれらのキーを追加してください。

# -------------------------------------------------------------------------
# 1. Supabase 設定 (Database Access)
# -------------------------------------------------------------------------
# Supabase > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# 必ず service_role キー（管理者特権キー）を使用してください (anonキーでは動きません)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -------------------------------------------------------------------------
# 2. Google APIs & Calendar Service Account 設定
# -------------------------------------------------------------------------
# Google Cloud Console で作成したサービスアカウントの認証情報。
GOOGLE_SERVICE_ACCOUNT_EMAIL=calendar-service-account@your-gcp-project.iam.gserviceaccount.com
# 秘密鍵（改行コード \n を含んだ1行の長いテキスト文字列として入力します）
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------------------------
# 3. Gmail SMTP 送信設定 (Nodemailer)
# -------------------------------------------------------------------------
# 体験予約確定時の自動返信メールを送るGmailアカウントのメールアドレス
GMAIL_USER=your-gym-email@gmail.com
# Google アカウントの「2段階認証プロセス」設定画面から生成した「アプリパスワード（16桁のアルファベット）」
GMAIL_PASS=xxxxwxxxyyyyzzzz

# -------------------------------------------------------------------------
# 4. アプリケーション全般設定
# -------------------------------------------------------------------------
# 管理画面に初回ログインする際の暗証コード
ADMIN_PIN=1234
# メールのキャンセル用リンクのベースURL (例: https://your-site-name.netlify.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
